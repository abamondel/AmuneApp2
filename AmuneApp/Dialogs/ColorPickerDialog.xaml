<Window x:Class="AmuneApp.Dialogs.ColorPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Choose Color" Width="440" Height="620"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="NoResize"
        MouseDown="Window_MouseDown">
    <Border CornerRadius="12" Padding="20"
            Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
            BorderBrush="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Opacity="0.3" ShadowDepth="4"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <TextBlock Grid.Row="0" Text="🎨 Choose Color" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>

            <!-- HSV Spectrum Canvas -->
            <Border Grid.Row="1" CornerRadius="8" ClipToBounds="True" Margin="0,0,0,8"
                    BorderBrush="LightGray" BorderThickness="1">
                <Canvas x:Name="spectrumCanvas" Height="160" Cursor="Cross"
                        MouseLeftButtonDown="Spectrum_MouseDown"
                        MouseMove="Spectrum_MouseMove"
                        MouseLeftButtonUp="Spectrum_MouseUp">
                    <!-- Rainbow horizontal gradient -->
                    <Rectangle x:Name="spectrumRect" Canvas.Left="0" Canvas.Top="0">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#FFFF0000" Offset="0.00"/>
                                <GradientStop Color="#FFFFFF00" Offset="0.17"/>
                                <GradientStop Color="#FF00FF00" Offset="0.33"/>
                                <GradientStop Color="#FF00FFFF" Offset="0.50"/>
                                <GradientStop Color="#FF0000FF" Offset="0.67"/>
                                <GradientStop Color="#FFFF00FF" Offset="0.83"/>
                                <GradientStop Color="#FFFF0000" Offset="1.00"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                    <!-- White-to-transparent top overlay -->
                    <Rectangle x:Name="spectrumWhite" Canvas.Left="0" Canvas.Top="0">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#FFFFFFFF" Offset="0.0"/>
                                <GradientStop Color="#00FFFFFF" Offset="1.0"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                    <!-- Transparent-to-black bottom overlay -->
                    <Rectangle x:Name="spectrumBlack" Canvas.Left="0" Canvas.Top="0">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#00000000" Offset="0.0"/>
                                <GradientStop Color="#FF000000" Offset="1.0"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                    <!-- Crosshair indicator -->
                    <Ellipse x:Name="spectrumCursor" Width="16" Height="16"
                             Stroke="White" StrokeThickness="2" Fill="Transparent"
                             IsHitTestVisible="False">
                        <Ellipse.Effect>
                            <DropShadowEffect BlurRadius="3" ShadowDepth="1" Opacity="0.5"/>
                        </Ellipse.Effect>
                    </Ellipse>
                </Canvas>
            </Border>

            <!-- Quick swatches -->
            <WrapPanel Grid.Row="2" x:Name="colorSwatches" Margin="0,0,0,8"/>

            <!-- RGB Sliders -->
            <Grid Grid.Row="3" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="45"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                </Grid.RowDefinitions>

                <TextBlock Text="R" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" FontWeight="Bold" Foreground="#FFE74C3C"/>
                <Slider x:Name="slR" Grid.Row="0" Grid.Column="1" Minimum="0" Maximum="255" VerticalAlignment="Center" ValueChanged="Slider_ValueChanged"/>
                <TextBlock x:Name="tbR" Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" Text="0" TextAlignment="Right"/>

                <TextBlock Text="G" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" FontWeight="Bold" Foreground="#FF2ECC71"/>
                <Slider x:Name="slG" Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="255" VerticalAlignment="Center" ValueChanged="Slider_ValueChanged"/>
                <TextBlock x:Name="tbG" Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" Text="0" TextAlignment="Right"/>

                <TextBlock Text="B" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" FontWeight="Bold" Foreground="#FF3498DB"/>
                <Slider x:Name="slB" Grid.Row="2" Grid.Column="1" Minimum="0" Maximum="255" VerticalAlignment="Center" ValueChanged="Slider_ValueChanged"/>
                <TextBlock x:Name="tbB" Grid.Row="2" Grid.Column="2" VerticalAlignment="Center" Text="0" TextAlignment="Right"/>
            </Grid>

            <!-- Hex input -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="Hex:" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="14"/>
                <TextBox x:Name="tbHex" Width="120" FontSize="14" FontFamily="Consolas"
                         TextAlignment="Center" MaxLength="7" LostFocus="tbHex_LostFocus"
                         KeyDown="tbHex_KeyDown"/>
            </StackPanel>

            <!-- Preview -->
            <Border Grid.Row="5" CornerRadius="8" Height="50" Margin="0,0,0,14"
                    BorderBrush="LightGray" BorderThickness="1">
                <Border x:Name="previewBorder" CornerRadius="7"/>
            </Border>

            <!-- Buttons -->
            <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button Content="OK" Width="110" Appearance="Primary" Click="OK_Click" Margin="0,0,8,0"/>
                <ui:Button Content="Cancel" Width="110" Appearance="Secondary" Click="Cancel_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
