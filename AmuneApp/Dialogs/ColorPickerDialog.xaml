<Window x:Class="AmuneApp.Dialogs.ColorPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Choose Color" Width="420" Height="520"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="NoResize">
    <Border CornerRadius="12" Padding="20"
            Background="{DynamicResource SystemChromeMediumColor}"
            BorderBrush="{DynamicResource SystemAccentColorPrimaryBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Opacity="0.3" ShadowDepth="4"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <TextBlock Grid.Row="0" Text="🎨 Choose Color" FontSize="20" FontWeight="Bold" Margin="0,0,0,12"/>

            <!-- Color swatches grid -->
            <WrapPanel Grid.Row="1" x:Name="colorSwatches" Margin="0,0,0,12"/>

            <!-- RGB Sliders -->
            <Grid Grid.Row="2" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="45"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                </Grid.RowDefinitions>

                <TextBlock Text="R" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" FontWeight="Bold" Foreground="#FFE74C3C"/>
                <Slider x:Name="slR" Grid.Row="0" Grid.Column="1" Minimum="0" Maximum="255" VerticalAlignment="Center" ValueChanged="Slider_ValueChanged"/>
                <TextBlock x:Name="tbR" Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" Text="0" TextAlignment="Right"/>

                <TextBlock Text="G" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" FontWeight="Bold" Foreground="#FF2ECC71"/>
                <Slider x:Name="slG" Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="255" VerticalAlignment="Center" ValueChanged="Slider_ValueChanged"/>
                <TextBlock x:Name="tbG" Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" Text="0" TextAlignment="Right"/>

                <TextBlock Text="B" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" FontWeight="Bold" Foreground="#FF3498DB"/>
                <Slider x:Name="slB" Grid.Row="2" Grid.Column="1" Minimum="0" Maximum="255" VerticalAlignment="Center" ValueChanged="Slider_ValueChanged"/>
                <TextBlock x:Name="tbB" Grid.Row="2" Grid.Column="2" VerticalAlignment="Center" Text="0" TextAlignment="Right"/>
            </Grid>

            <!-- Hex input -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,12">
                <TextBlock Text="Hex:" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="14"/>
                <TextBox x:Name="tbHex" Width="120" FontSize="14" FontFamily="Consolas"
                         TextAlignment="Center" MaxLength="7" LostFocus="tbHex_LostFocus"
                         KeyDown="tbHex_KeyDown"/>
            </StackPanel>

            <!-- Preview -->
            <Border Grid.Row="4" CornerRadius="8" Height="60" Margin="0,0,0,12"
                    BorderBrush="Gray" BorderThickness="1">
                <Border x:Name="previewBorder" CornerRadius="7"/>
            </Border>

            <!-- Buttons -->
            <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button Content="OK" Width="100" Appearance="Primary" Click="OK_Click" Margin="0,0,8,0"/>
                <ui:Button Content="Cancel" Width="100" Appearance="Secondary" Click="Cancel_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
