<Window x:Class="AmuneApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:usercontrols="clr-namespace:AmuneApp.UserControls"
        Title="AmuneApp" Height="140" Width="745"
        Icon="Resources/app.ico"
        WindowStyle="None"
        WindowStartupLocation="Manual"
        MouseDown="Window_MouseDown"
        Closing="Window_Closing"
        AllowsTransparency="True" Background="#00A9A9A9" Opacity="1"
        ShowInTaskbar="False">
    <Window.ContextMenu>
        <ContextMenu>
            <MenuItem Header="📝 Edit Pusikim" Click="EditPusikim_Click"/>
            <Separator/>
            <MenuItem x:Name="miTimer" Header="⏱ Display Timer">
                <MenuItem Header="1 second" Tag="1" Click="TimerOption_Click"/>
                <MenuItem Header="2 seconds" Tag="2" Click="TimerOption_Click"/>
                <MenuItem Header="3 seconds" Tag="3" Click="TimerOption_Click"/>
                <MenuItem Header="5 seconds" Tag="5" Click="TimerOption_Click"/>
                <MenuItem Header="10 seconds" Tag="10" Click="TimerOption_Click"/>
                <MenuItem Header="15 seconds" Tag="15" Click="TimerOption_Click"/>
                <MenuItem Header="30 seconds" Tag="30" Click="TimerOption_Click"/>
            </MenuItem>
            <MenuItem x:Name="miOpacity" Header="🔆 Opacity">
                <MenuItem Header="25%" Tag="0.25" Click="OpacityOption_Click"/>
                <MenuItem Header="50%" Tag="0.50" Click="OpacityOption_Click"/>
                <MenuItem Header="75%" Tag="0.75" Click="OpacityOption_Click"/>
                <MenuItem Header="100%" Tag="1.0" Click="OpacityOption_Click"/>
            </MenuItem>
            <Separator/>
            <MenuItem x:Name="miShuffle" Click="miShuffle_Click">
                <MenuItem.Header>
                    <CheckBox Content="🔀 Shuffle Mode" IsHitTestVisible="False" VerticalAlignment="Center"/>
                </MenuItem.Header>
            </MenuItem>
            <MenuItem x:Name="miStartOnStartup" Click="miStartOnStartup_Click">
                <MenuItem.Header>
                    <CheckBox Content="🚀 Start on PC Startup" IsHitTestVisible="False" VerticalAlignment="Center"/>
                </MenuItem.Header>
            </MenuItem>
            <MenuItem x:Name="miDarkMode" Click="miDarkMode_Click">
                <MenuItem.Header>
                    <CheckBox Content="🌙 Dark Mode" IsHitTestVisible="False" VerticalAlignment="Center"/>
                </MenuItem.Header>
            </MenuItem>
            <Separator/>
            <MenuItem Header="🔤 Change Font..." Click="ChangeFont_Click"/>
            <MenuItem Header="🎨 Background Color..." Click="ChangeBackground_Click"/>
            <Separator/>
            <MenuItem Header="📥 Import Sentences..." Click="ImportSentences_Click"/>
            <MenuItem Header="📤 Export Sentences..." Click="ExportSentences_Click"/>
            <Separator/>
            <MenuItem Header="❌ Quit" Click="QuitApp_Click"/>
        </ContextMenu>
    </Window.ContextMenu>
    <Grid>
        <Popup x:Name="addStringPopup" Placement="Mouse" AllowsTransparency="True" PopupAnimation="Fade" StaysOpen="False">
            <Border Width="400" CornerRadius="10" Background="#FFDDDDDD" Padding="10">
                <StackPanel>
                    <ScrollViewer Padding="5" MaxHeight="300">
                        <StackPanel x:Name="popupSp"/>
                    </ScrollViewer>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,4" x:Name="stNewSentence">
                        <TextBox x:Name="tbAddSentence"
                                 Width="320" Margin="5,0,5,0"
                                 FontSize="18" FontWeight="SemiBold"
                                 TextAlignment="Right"
                                 KeyDown="tbAddSentence_KeyDown"/>
                        <Button Content="+" FontSize="18" FontWeight="Bold"
                                Width="35" Height="35" Click="btnAddNew_Click"/>
                    </StackPanel>
                    <Separator x:Name="popupSeparator" Margin="0,8,0,5"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <ui:Button Margin="5" Width="100" Content="Save"
                                   Appearance="Primary" Click="AddButton_Click"/>
                        <ui:Button Margin="5" Width="100" Content="Cancel"
                                   Appearance="Secondary" Click="btCancel_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Popup>

        <Rectangle StrokeThickness="4" x:Name="rbWindowColor" RadiusX="25" RadiusY="25">
            <Rectangle.Fill>
                <SolidColorBrush x:Name="windowBgBrush" Color="#CCFFFFFF"/>
            </Rectangle.Fill>
            <Rectangle.Stroke>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="Black"/>
                    <GradientStop Color="#FFD80000" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Stroke>
        </Rectangle>

        <StackPanel Margin="20" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Orientation="Horizontal" x:Name="spTextGrid" FlowDirection="RightToLeft">
            <TextBlock Text=".אין שומע לי ומפסיד" x:Name="sentenceTextBlock"
                       FontSize="64" FontWeight="Bold" FontFamily="David"
                       TextAlignment="Center" VerticalAlignment="Center"
                       Cursor="Hand" ToolTip="Double-click to copy"
                       PreviewMouseLeftButtonDown="SentenceTextBlock_PreviewMouseDown">
                <TextBlock.Foreground>
                    <RadialGradientBrush SpreadMethod="Pad" MappingMode="RelativeToBoundingBox">
                        <RadialGradientBrush.RelativeTransform>
                            <TransformGroup>
                                <ScaleTransform CenterY="0.5" CenterX="0.5"/>
                                <SkewTransform CenterX="0.5" CenterY="0.5"/>
                                <RotateTransform CenterX="0.5" CenterY="0.5"/>
                                <TranslateTransform X="0.2"/>
                            </TransformGroup>
                        </RadialGradientBrush.RelativeTransform>
                        <GradientStop Color="#FF9154FF" Offset="1"/>
                        <GradientStop Color="#FF1E0056"/>
                    </RadialGradientBrush>
                </TextBlock.Foreground>
            </TextBlock>
        </StackPanel>

        <TextBlock x:Name="tbCounter" Text="0 / 0"
                   FontSize="12" Foreground="Gray"
                   HorizontalAlignment="Right" VerticalAlignment="Bottom"
                   Margin="0,0,15,8"/>
    </Grid>
</Window>
