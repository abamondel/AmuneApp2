<Window x:Class="AmuneApp.FloatingTextWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowState="Maximized"
        IsHitTestVisible="False">
    <Canvas x:Name="canvas">
        <TextBlock x:Name="floatingText"
                   FontSize="72"
                   FontWeight="Bold"
                   FontFamily="David"
                   FlowDirection="RightToLeft"
                   Canvas.Top="0">
            <TextBlock.Foreground>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#FF9154FF" Offset="0"/>
                    <GradientStop Color="#FF1E0056" Offset="1"/>
                </LinearGradientBrush>
            </TextBlock.Foreground>
            <TextBlock.Effect>
                <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="2" Opacity="0.6"/>
            </TextBlock.Effect>
        </TextBlock>
    </Canvas>
</Window>
