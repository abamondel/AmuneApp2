<UserControl x:Class="AmuneApp.UserControls.AddSentenceControle"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AmuneApp.UserControls"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d" Height="Auto" Width="Auto"
           Name="this" 
             Loaded="UserControl_Loaded"
             >
    <Grid>
        <StackPanel Margin="0,5,0,5"   HorizontalAlignment="Stretch"  Orientation="Horizontal">
            <TextBox x:Name="tbAddSentence" Width="300" TextAlignment="Right" FontSize="18" FontWeight="SemiBold" Margin="5,0,5,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Right" />
            <Button Height="{Binding ActualHeight, ElementName=tbAddSentence}" PreviewMouseLeftButtonUp="btnDelete_PreviewMouseLeftButtonUp" HorizontalAlignment="Right" x:Name="btnDelete" >
                <ui:SymbolIcon Symbol="Delete48"/>
            </Button>
          
        </StackPanel>
    </Grid>
</UserControl>
